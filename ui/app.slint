import { Button, LineEdit, StandardButton, VerticalBox, HorizontalBox, TabWidget, CheckBox, ComboBox, GridBox, GroupBox, ScrollView } from "std-widgets.slint";

export struct SearchResult {
    name: string,
    icon: string,
    path: string,
    comment: string,
}

export struct DesktopFileData {
    path: string,
    is-new: bool,
    has-changes: bool,
    name: string,
    generic-name: string,
    comment: string,
    icon: string,
    exec: string,
    try-exec: string,
    desktop-type: string,
    categories: string,
    mime-types: string,
    keywords: string,
    startup-wm-class: string,
    terminal: bool,
    startup-notify: bool,
    no-display: bool,
    hidden: bool,
    dbus-activatable: bool,
    working-dir: string,
    only-show-in: string,
    not-show-in: string,
    actions: string,
    implements: string,
    raw-keys: [string],
    raw-values: [string],
}

export component AppWindow inherits Window {
    title: "Desktop Entry Editor";
    preferred-width: 1100px;
    preferred-height: 750px;
    min-width: 800px;
    min-height: 600px;

    // --- State ---
    in-out property <[SearchResult]> search-results: [];
    in-out property <int> selected-index: -1;
    in-out property <string> search-query: "";
    in-out property <string> status-text: "Ready";
    in-out property <DesktopFileData> current-file: {
        path: "", is-new: true, has-changes: false,
        name: "", generic-name: "", comment: "", icon: "", exec: "", try-exec: "",
        desktop-type: "Application", categories: "", mime-types: "", keywords: "",
        startup-wm-class: "", terminal: false, startup-notify: false, no-display: false,
        hidden: false, dbus-activatable: false, working-dir: "", only-show-in: "",
        not-show-in: "", actions: "", implements: "",
        raw-keys: [], raw-values: [],
    };
    in-out property <bool> has-selection: false;
    in-out property <bool> unsaved-changes: false;
    in-out property <bool> loading: false;

    // --- Callbacks to Rust ---
    callback scan-entries();
    callback search(string) -> [SearchResult];
    callback load-entry(int) -> DesktopFileData;
    callback save-entry();
    callback new-entry();
    callback delete-entry();
    callback open-in-editor();
    callback reload-entry();

    // --- Layout ---
    HorizontalLayout {
        // === Left sidebar ===
        Rectangle {
            width: 340px;
            background: #1a1d23;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: "Desktop Entries";
                    font-size: 20px;
                    font-weight: 700;
                    color: #eff0f1;
                }

                Text {
                    text: "Search installed .desktop files and edit their properties.";
                    font-size: 12px;
                    color: #aeb6c2;
                    wrap: word-wrap;
                }

                // Search field
                Rectangle {
                    height: 36px;
                    border-radius: 6px;
                    background: #2a2f3a;
                    border-width: 1px;
                    border-color: #3b4252;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;

                        Text {
                            text: "🔍";
                            vertical-alignment: center;
                            font-size: 14px;
                        }

                        search-input := LineEdit {
                            font-size: 13px;
                            placeholder-text: "Search desktop files...";
                            text: root.search-query;

                            edited => {
                                root.search-query = self.text;
                                root.search-results = root.search(self.text);
                            }
                        }
                    }
                }

                Text {
                    text: root.status-text;
                    font-size: 12px;
                    color: #aeb6c2;
                }

                // Results list
                ScrollView {
                    VerticalLayout {
                        spacing: 6px;

                        for result[idx] in root.search-results: Rectangle {
                            height: 62px;
                            background: idx == root.selected-index ? #5294e240 : (mouse-area.has-hover ? #ffffff08 : transparent);
                            border-radius: 6px;

                            mouse-area := TouchArea {
                                clicked => {
                                    root.selected-index = idx;
                                    root.loading = true;
                                    root.current-file = root.load-entry(idx);
                                    root.has-selection = true;
                                    root.loading = false;
                                    root.unsaved-changes = false;
                                }
                            }

                            HorizontalLayout {
                                padding: 10px;
                                spacing: 12px;

                                Rectangle {
                                    width: 40px;
                                    height: 40px;
                                    border-radius: 8px;
                                    background: #2a2f3a;

                                    Text {
                                        text: result.icon != "" ? "📦" : "📄";
                                        font-size: 20px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                VerticalLayout {
                                    spacing: 2px;

                                    Text {
                                        text: result.name;
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: #eff0f1;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: result.comment != "" ? result.comment : result.path;
                                        font-size: 11px;
                                        color: #8892a0;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;

                    Button {
                        text: "Rescan";
                        clicked => { root.scan-entries(); }
                    }

                    Button {
                        text: "+ New";
                        clicked => { root.new-entry(); }
                    }
                }
            }
        }

        // === Right panel ===
        Rectangle {
            background: #21252b;

            // Empty state
            if !root.has-selection: VerticalLayout {
                alignment: center;
                spacing: 16px;

                Text {
                    text: "Select a desktop file";
                    font-size: 28px;
                    font-weight: 700;
                    color: #eff0f1;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Choose an entry from the list to inspect and edit its properties.";
                    font-size: 14px;
                    color: #aeb6c2;
                    horizontal-alignment: center;
                }
            }

            // Editor
            if root.has-selection && !root.loading: VerticalLayout {
                padding: 20px;
                spacing: 16px;

                // Header
                HorizontalLayout {
                    spacing: 16px;

                    Rectangle {
                        width: 64px;
                        height: 64px;
                        border-radius: 12px;
                        background: #2a2f3a;
                        border-width: 1px;
                        border-color: #3b4252;

                        Text {
                            text: "📦";
                            font-size: 28px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        vertical-stretch: 0;

                        Text {
                            text: root.current-file.name != "" ? root.current-file.name : "Untitled";
                            font-size: 24px;
                            font-weight: 700;
                            color: #eff0f1;
                        }

                        Rectangle {
                            height: 28px;
                            border-radius: 4px;
                            background: #1a1d23;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;

                                Text {
                                    text: root.current-file.path;
                                    font-size: 11px;
                                    color: #8892a0;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }

                        if root.unsaved-changes: Rectangle {
                            height: 20px;
                            border-radius: 4px;
                            background: #e5a50a20;

                            Text {
                                text: "● Unsaved changes";
                                font-size: 11px;
                                color: #e5a50a;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                // Tabs
                TabWidget {
                    Tab {
                        title: "General";

                        ScrollView {
                            VerticalLayout {
                                spacing: 12px;
                                padding: 8px;

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Name"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.name;
                                        edited => { root.current-file.name = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Generic Name"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.generic-name;
                                        edited => { root.current-file.generic-name = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Comment"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.comment;
                                        edited => { root.current-file.comment = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Icon"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.icon;
                                        edited => { root.current-file.icon = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Exec"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.exec;
                                        edited => { root.current-file.exec = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "TryExec"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.try-exec;
                                        edited => { root.current-file.try-exec = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Working Directory"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.working-dir;
                                        edited => { root.current-file.working-dir = self.text; root.unsaved-changes = true; }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "Categories";

                        ScrollView {
                            VerticalLayout {
                                spacing: 12px;
                                padding: 8px;

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Type"; font-size: 12px; color: #aeb6c2; }
                                    ComboBox {
                                        model: ["Application", "Link", "Directory"];
                                        current-value: root.current-file.desktop-type;
                                        selected(value) => {
                                            root.current-file.desktop-type = value;
                                            root.unsaved-changes = true;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Categories"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.categories;
                                        edited => { root.current-file.categories = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Mime Types"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.mime-types;
                                        edited => { root.current-file.mime-types = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Keywords"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.keywords;
                                        edited => { root.current-file.keywords = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Startup WM Class"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.startup-wm-class;
                                        edited => { root.current-file.startup-wm-class = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Only Show In"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.only-show-in;
                                        edited => { root.current-file.only-show-in = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Not Show In"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.not-show-in;
                                        edited => { root.current-file.not-show-in = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Implements"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.implements;
                                        edited => { root.current-file.implements = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Actions"; font-size: 12px; color: #aeb6c2; }
                                    LineEdit {
                                        text: root.current-file.actions;
                                        edited => { root.current-file.actions = self.text; root.unsaved-changes = true; }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "Flags";

                        VerticalLayout {
                            spacing: 16px;
                            padding: 16px;

                            GroupBox {
                                title: "Display & Behavior";

                                VerticalLayout {
                                    spacing: 12px;

                                    CheckBox {
                                        text: "Run in Terminal";
                                        checked: root.current-file.terminal;
                                        toggled => { root.current-file.terminal = self.checked; root.unsaved-changes = true; }
                                    }

                                    CheckBox {
                                        text: "Startup Notify";
                                        checked: root.current-file.startup-notify;
                                        toggled => { root.current-file.startup-notify = self.checked; root.unsaved-changes = true; }
                                    }

                                    CheckBox {
                                        text: "No Display (hide from menus)";
                                        checked: root.current-file.no-display;
                                        toggled => { root.current-file.no-display = self.checked; root.unsaved-changes = true; }
                                    }

                                    CheckBox {
                                        text: "Hidden (do not show)";
                                        checked: root.current-file.hidden;
                                        toggled => { root.current-file.hidden = self.checked; root.unsaved-changes = true; }
                                    }

                                    CheckBox {
                                        text: "D-Bus Activatable";
                                        checked: root.current-file.dbus-activatable;
                                        toggled => { root.current-file.dbus-activatable = self.checked; root.unsaved-changes = true; }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "Raw";

                        ScrollView {
                            VerticalLayout {
                                spacing: 8px;
                                padding: 8px;

                                Text {
                                    text: "Raw desktop file keys and values. Edit values directly.";
                                    font-size: 12px;
                                    color: #8892a0;
                                    wrap: word-wrap;
                                }

                                for key[idx] in root.current-file.raw-keys: HorizontalLayout {
                                    spacing: 8px;
                                    height: 32px;

                                    Rectangle {
                                        width: 180px;
                                        background: #1a1d23;
                                        border-radius: 4px;

                                        Text {
                                            text: key;
                                            font-size: 12px;
                                            font-family: "monospace";
                                            color: #5294e2;
                                            vertical-alignment: center;
                                            x: 8px;
                                        }
                                    }

                                    Rectangle {
                                        background: #2a2f3a;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: #3b4252;

                                        raw-input := LineEdit {
                                            text: root.current-file.raw-values[idx];
                                            font-size: 12px;
                                            font-family: "monospace";
                                            x: 8px;

                                            edited => {
                                                root.current-file.raw-values[idx] = self.text;
                                                root.unsaved-changes = true;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Bottom action bar
                HorizontalLayout {
                    spacing: 8px;
                    vertical-stretch: 0;

                    Button {
                        text: "Save";
                        enabled: root.unsaved-changes;
                        clicked => {
                            root.save-entry();
                            root.unsaved-changes = false;
                        }
                    }

                    Button {
                        text: "Reload";
                        clicked => {
                            root.reload-entry();
                            root.unsaved-changes = false;
                        }
                    }

                    Button {
                        text: "Open in Editor";
                        clicked => { root.open-in-editor(); }
                    }

                    Rectangle { horizontal-stretch: 1; }

                    Button {
                        text: "Delete";
                        clicked => { root.delete-entry(); }
                    }
                }
            }

            // Loading overlay
            if root.loading: Rectangle {
                background: #21252b80;
                Text {
                    text: "Loading...";
                    font-size: 16px;
                    color: #aeb6c2;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
