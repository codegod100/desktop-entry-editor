import { Button, LineEdit, StandardButton, VerticalBox, HorizontalBox, TabWidget, CheckBox, ComboBox, GridBox, GroupBox, AboutSlint } from "std-widgets.slint";

// A single desktop entry shown in the list
struct DesktopEntry {
    name: string,
    icon: string,
    path: string,
    exec: string,
    comment: string,
    desktop-type: string,
    categories: string,
    mime-types: string,
    terminal: bool,
    startup-notify: bool,
    no-display: bool,
    // Raw key-value pairs for the editor
    raw-keys: [string],
    raw-values: [string],
}

// Full desktop file with all sections
struct DesktopFileData {
    path: string,
    is-new: bool,
    has-changes: bool,
    // Main section fields
    name: string,
    generic-name: string,
    comment: string,
    icon: string,
    exec: string,
    try-exec: string,
    desktop-type: string,
    categories: string,
    mime-types: string,
    keywords: string,
    startup-wm-class: string,
    terminal: bool,
    startup-notify: bool,
    no-display: bool,
    hidden: bool,
    dbus-activatable: bool,
    path: string,
    only-show-in: string,
    not-show-in: string,
    actions: string,
    implements: string,
    // Full raw key-value pairs for advanced editing
    raw-keys: [string],
    raw-values: [string],
}

export struct SearchResult := struct {
    name: string,
    icon: string,
    path: string,
    comment: string,
}

export component AppWindow inherits Window {
    title: "Desktop Entry Editor";
    preferred-width: 1100px;
    preferred-height: 750px;
    min-width: 800px;
    min-height: 600px;

    // --- State ---
    in-out property <[SearchResult]> search-results: [];
    in-out property <int> selected-index: -1;
    in-out property <string> search-query: "";
    in-out property <string> status-text: "Ready";

    // Detail panel
    in-out property <DesktopFileData> current-file: {
        path: "",
        is-new: true,
        has-changes: false,
        name: "",
        generic-name: "",
        comment: "",
        icon: "",
        exec: "",
        try-exec: "",
        desktop-type: "Application",
        categories: "",
        mime-types: "",
        keywords: "",
        startup-wm-class: "",
        terminal: false,
        startup-notify: false,
        no-display: false,
        hidden: false,
        dbus-activatable: false,
        path: "",
        only-show-in: "",
        not-show-in: "",
        actions: "",
        implements: "",
        raw-keys: [],
        raw-values: [],
    };

    in-out property <bool> has-selection: false;
    in-out property <bool> unsaved-changes: false;
    in-out property <bool> loading: false;
    in-out property <int> raw-edit-count: 0;

    // --- Callbacks to Rust ---
    callback scan-entries();
    callback search(string) -> [SearchResult];
    callback load-entry(int) -> DesktopFileData;
    callback save-entry();
    callback new-entry();
    callback delete-entry();
    callback open-in-editor();
    callback validate-entry() -> string;
    callback reload-entry();
    callback install-entry();

    // --- Layout ---

    HorizontalLayout {
        // Left sidebar: search + results
        Rectangle {
            width: 340px;
            background: #1a1d23;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                // Header
                Text {
                    text: "Desktop Entries";
                    font-size: 20px;
                    font-weight: 700;
                    color: #eff0f1;
                }

                Text {
                    text: "Search installed .desktop files and edit their properties.";
                    font-size: 12px;
                    color: #aeb6c2;
                    wrap-mode: word-wrap;
                }

                // Search field
                Rectangle {
                    height: 36px;
                    border-radius: 6px;
                    background: #2a2f3a;
                    border-width: 1px;
                    border-color: search-field.has-focus ? #5294e2 : #3b4252;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 8px;

                        Text {
                            text: "🔍";
                            vertical-alignment: center;
                            font-size: 14px;
                        }

                        TouchArea {
                            layout := TextInput {
                                vertical-alignment: center;
                                id := search-field;
                                font-size: 13px;
                                color: #eff0f1;
                                placeholder-text: "Search desktop files...";
                                text: root.search-query;

                                edited(key) => {
                                    root.search-query = self.text;
                                    root.search-results = root.search(self.text);
                                }
                            }
                        }
                    }
                }

                // Status
                Text {
                    text: root.status-text;
                    font-size: 12px;
                    color: #aeb6c2;
                }

                // Results list
                ListView {
                    id := results-list;
                    current: root.selected-index;

                    for result[idx] in root.search-results: Rectangle {
                        height: 62px;
                        selected: idx == root.selected-index;
                        background: idx == root.selected-index ? #5294e240 : (mouse-area.hover ? #ffffff08 : transparent);
                        border-radius: 6px;

                        mouse-area := TouchArea {
                            clicked => {
                                root.selected-index = idx;
                                root.loading = true;
                                root.current-file = root.load-entry(idx);
                                root.has-selection = true;
                                root.loading = false;
                                root.unsaved-changes = false;
                            }
                        }

                        HorizontalLayout {
                            padding: 10px;
                            spacing: 12px;

                            // Icon placeholder
                            Rectangle {
                                width: 40px;
                                height: 40px;
                                border-radius: 8px;
                                background: #2a2f3a;

                                Text {
                                    text: result.icon != "" ? "📦" : "📄";
                                    font-size: 20px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            VerticalLayout {
                                spacing: 2px;

                                Text {
                                    text: result.name;
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: #eff0f1;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: result.comment != "" ? result.comment : result.path;
                                    font-size: 11px;
                                    color: #8892a0;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }

                // Bottom buttons
                HorizontalLayout {
                    spacing: 8px;

                    Button {
                        text: "⟳ Rescan";
                        clicked => { root.scan-entries(); }
                    }

                    Button {
                        text: "+ New";
                        clicked => { root.new-entry(); }
                    }
                }
            }
        }

        // Right panel: editor details
        Rectangle {
            background: #21252b;

            if !root.has-selection: VerticalLayout {
                alignment: center;
                spacing: 16px;

                Text {
                    text: "Select a desktop file";
                    font-size: 28px;
                    font-weight: 700;
                    color: #eff0f1;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Choose an entry from the list to inspect and edit its properties.";
                    font-size: 14px;
                    color: #aeb6c2;
                    horizontal-alignment: center;
                }
            }

            if root.has-selection && !root.loading: VerticalLayout {
                padding: 20px;
                spacing: 16px;

                // Header with icon + name
                HorizontalLayout {
                    spacing: 16px;

                    Rectangle {
                        width: 64px;
                        height: 64px;
                        border-radius: 12px;
                        background: #2a2f3a;
                        border-width: 1px;
                        border-color: #3b4252;

                        Text {
                            text: "📦";
                            font-size: 28px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        vertical-stretch: 0;

                        Text {
                            text: root.current-file.name != "" ? root.current-file.name : "Untitled";
                            font-size: 24px;
                            font-weight: 700;
                            color: #eff0f1;
                        }

                        Rectangle {
                            height: 28px;
                            border-radius: 4px;
                            background: #1a1d23;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;
                                spacing: 4px;

                                Text {
                                    text: root.current-file.path;
                                    font-size: 11px;
                                    color: #8892a0;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }

                        if root.unsaved-changes: Rectangle {
                            height: 20px;
                            border-radius: 4px;
                            background: #e5a50a20;

                            Text {
                                text: "● Unsaved changes";
                                font-size: 11px;
                                color: #e5a50a;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                // Tab widget
                TabWidget {
                    Tab {
                        title: "General";

                        ScrollView {
                            VerticalLayout {
                                spacing: 12px;
                                padding: 8px;

                                // Name
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Name"; font-size: 12px; color: #aeb6c2; }
                                    field-name := LineEdit {
                                        text: root.current-file.name;
                                        edited => { root.current-file.name = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // Generic Name
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Generic Name"; font-size: 12px; color: #aeb6c2; }
                                    field-generic-name := LineEdit {
                                        text: root.current-file.generic-name;
                                        edited => { root.current-file.generic-name = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // Comment
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Comment"; font-size: 12px; color: #aeb6c2; }
                                    field-comment := LineEdit {
                                        text: root.current-file.comment;
                                        edited => { root.current-file.comment = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // Icon
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Icon"; font-size: 12px; color: #aeb6c2; }
                                    field-icon := LineEdit {
                                        text: root.current-file.icon;
                                        edited => { root.current-file.icon = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // Exec
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Exec"; font-size: 12px; color: #aeb6c2; }
                                    field-exec := LineEdit {
                                        text: root.current-file.exec;
                                        edited => { root.current-file.exec = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // TryExec
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "TryExec"; font-size: 12px; color: #aeb6c2; }
                                    field-try-exec := LineEdit {
                                        text: root.current-file.try-exec;
                                        edited => { root.current-file.try-exec = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // Path (working directory)
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Working Directory"; font-size: 12px; color: #aeb6c2; }
                                    field-work-dir := LineEdit {
                                        text: root.current-file.path;
                                        edited => { root.current-file.path = self.text; root.unsaved-changes = true; }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "Type & Categories";

                        ScrollView {
                            VerticalLayout {
                                spacing: 12px;
                                padding: 8px;

                                // Type
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Type"; font-size: 12px; color: #aeb6c2; }
                                    field-type := ComboBox {
                                        model: ["Application", "Link", "Directory"];
                                        current-value: root.current-file.desktop-type;
                                        selected(value) => { root.current-file.desktop-type = value; root.unsaved-changes = true; }
                                    }
                                }

                                // Categories
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Categories"; font-size: 12px; color: #aeb6c2; }
                                    field-categories := LineEdit {
                                        text: root.current-file.categories;
                                        edited => { root.current-file.categories = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // MimeTypes
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Mime Types"; font-size: 12px; color: #aeb6c2; }
                                    field-mimetypes := LineEdit {
                                        text: root.current-file.mime-types;
                                        edited => { root.current-file.mime-types = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // Keywords
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Keywords"; font-size: 12px; color: #aeb6c2; }
                                    field-keywords := LineEdit {
                                        text: root.current-file.keywords;
                                        edited => { root.current-file.keywords = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // StartupWMClass
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Startup WM Class"; font-size: 12px; color: #aeb6c2; }
                                    field-wm-class := LineEdit {
                                        text: root.current-file.startup-wm-class;
                                        edited => { root.current-file.startup-wm-class = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // OnlyShowIn
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Only Show In"; font-size: 12px; color: #aeb6c2; }
                                    field-only-show-in := LineEdit {
                                        text: root.current-file.only-show-in;
                                        edited => { root.current-file.only-show-in = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // NotShowIn
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Not Show In"; font-size: 12px; color: #aeb6c2; }
                                    field-not-show-in := LineEdit {
                                        text: root.current-file.not-show-in;
                                        edited => { root.current-file.not-show-in = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // Implements
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Implements"; font-size: 12px; color: #aeb6c2; }
                                    field-implements := LineEdit {
                                        text: root.current-file.implements;
                                        edited => { root.current-file.implements = self.text; root.unsaved-changes = true; }
                                    }
                                }

                                // Actions
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "Actions"; font-size: 12px; color: #aeb6c2; }
                                    field-actions := LineEdit {
                                        text: root.current-file.actions;
                                        edited => { root.current-file.actions = self.text; root.unsaved-changes = true; }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "Flags";

                        VerticalLayout {
                            spacing: 16px;
                            padding: 16px;

                            GroupBox {
                                title: "Display & Behavior";

                                VerticalLayout {
                                    spacing: 12px;

                                    chk-terminal := CheckBox {
                                        text: "Run in Terminal";
                                        checked: root.current-file.terminal;
                                        toggled => { root.current-file.terminal = self.checked; root.unsaved-changes = true; }
                                    }

                                    chk-startup-notify := CheckBox {
                                        text: "Startup Notify";
                                        checked: root.current-file.startup-notify;
                                        toggled => { root.current-file.startup-notify = self.checked; root.unsaved-changes = true; }
                                    }

                                    chk-no-display := CheckBox {
                                        text: "No Display (hide from menus)";
                                        checked: root.current-file.no-display;
                                        toggled => { root.current-file.no-display = self.checked; root.unsaved-changes = true; }
                                    }

                                    chk-hidden := CheckBox {
                                        text: "Hidden (do not show)";
                                        checked: root.current-file.hidden;
                                        toggled => { root.current-file.hidden = self.checked; root.unsaved-changes = true; }
                                    }

                                    chk-dbus := CheckBox {
                                        text: "D-Bus Activatable";
                                        checked: root.current-file.dbus-activatable;
                                        toggled => { root.current-file.dbus-activatable = self.checked; root.unsaved-changes = true; }
                                    }
                                }
                            }
                        }
                    }

                    Tab {
                        title: "Raw";

                        VerticalLayout {
                            spacing: 8px;
                            padding: 8px;

                            Text {
                                text: "Raw desktop file keys and values. Edit values directly.";
                                font-size: 12px;
                                color: #8892a0;
                                wrap-mode: word-wrap;
                            }

                            raw-grid := VerticalLayout {
                                spacing: 4px;

                                for key[idx] in root.current-file.raw-keys: HorizontalLayout {
                                    spacing: 8px;
                                    height: 32px;

                                    Rectangle {
                                        width: 180px;
                                        background: #1a1d23;
                                        border-radius: 4px;

                                        Text {
                                            text: key;
                                            font-size: 12px;
                                            font-family: "monospace";
                                            color: #5294e2;
                                            vertical-alignment: center;
                                            x: 8px;
                                        }
                                    }

                                    Rectangle {
                                        background: #2a2f3a;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: raw-input.has-focus ? #5294e2 : #3b4252;

                                        raw-input := TextInput {
                                            text: root.current-file.raw-values[idx];
                                            font-size: 12px;
                                            font-family: "monospace";
                                            color: #eff0f1;
                                            vertical-alignment: center;
                                            x: 8px;

                                            edited => {
                                                root.current-file.raw-values[idx] = self.text;
                                                root.unsaved-changes = true;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Action bar at bottom
                HorizontalLayout {
                    spacing: 8px;
                    vertical-stretch: 0;

                    Button {
                        text: "💾 Save";
                        primary: true;
                        enabled: root.unsaved-changes;
                        clicked => {
                            root.save-entry();
                            root.unsaved-changes = false;
                        }
                    }

                    Button {
                        text: "↩ Reload";
                        clicked => {
                            root.reload-entry();
                            root.unsaved-changes = false;
                        }
                    }

                    Button {
                        text: "📋 Open in Editor";
                        clicked => { root.open-in-editor(); }
                    }

                    Rectangle { horizontal-stretch: 1; }

                    Button {
                        text: "🗑 Delete";
                        colorize-icon: true;
                        clicked => { root.delete-entry(); }
                    }
                }
            }

            // Loading overlay
            if root.loading: Rectangle {
                background: #21252b80;
                Text {
                    text: "Loading...";
                    font-size: 16px;
                    color: #aeb6c2;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
